DATABASE_URL="file:./dev.db"
PORT=3001
# Comma-separated allowed origins (dev frontend runs on 8080)
CORS_ORIGIN="http://localhost:8080"

# Auth cookie settings:
# - For same-apex-domain prod (e.g. www.example.com + shop.example.com), set DOMAIN=".example.com"
# - For local dev, leave empty
SESSION_COOKIE_NAME="bd_session"
# SESSION_COOKIE_DOMAIN=".example.com"
SESSION_DAYS=30

# Admin (optional): restrict admin endpoints to these emails (comma-separated) in production
# ADMIN_EMAILS="you@domain.com,other@domain.com"

# WooCommerce (for exact product photos + catalog sync)
# Store API may be blocked by WAF; REST API with credentials is the reliable source.
# WOO_REST_BASE="https://bluediamonds.club/wp-json/wc/v3/products"
# WOO_CONSUMER_KEY="ck_..."
# WOO_CONSUMER_SECRET="cs_..."

# Payments (Stripe Checkout)
# Use test keys in dev. In production, use live keys.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# NODE_ENV=production

