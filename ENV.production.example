# Production Environment Variables
# Copy this to .env and fill in your values

# ============================================
# DATABASE (VERPLICHT)
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Examples:
#   Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
#   Railway: postgresql://postgres:[PASSWORD]@[HOST]:5432/railway
#   Render: postgresql://[USER]:[PASSWORD]@[HOST]:5432/[DB]
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ============================================
# CORS (VERPLICHT)
# ============================================
# Comma-separated list of allowed origins
# Include all domains where your frontend is hosted
CORS_ORIGIN="https://www.bluediamonds.club,https://bluediamonds.club"

# ============================================
# SESSION (VERPLICHT)
# ============================================
SESSION_COOKIE_NAME="bd_session"
# Set to .bluediamonds.club if you want sessions to work across subdomains
SESSION_COOKIE_DOMAIN=".bluediamonds.club"
SESSION_DAYS=30

# ============================================
# STRIPE (AANBEVOLEN - voor checkout)
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_..."
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# WOOCOMMERCE (OPTIONEEL - voor product sync)
# ============================================
# Only needed if you want to sync products from WooCommerce
WOO_REST_BASE="https://bluediamonds.club/wp-json/wc/v3/products"
WOO_CONSUMER_KEY="ck_..."
WOO_CONSUMER_SECRET="cs_..."

# ============================================
# ADMIN (OPTIONEEL)
# ============================================
# Comma-separated list of admin emails
# These emails can access admin endpoints
ADMIN_EMAILS="admin@bluediamonds.club"

# ============================================
# SERVER (OPTIONEEL)
# ============================================
PORT=3001
NODE_ENV=production
